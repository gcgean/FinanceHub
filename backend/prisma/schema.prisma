// AI Module

model AIProfile {
  id        String   @id @default(cuid())
  companyId String   @unique
  company   Company  @relation(fields: [companyId], references: [id])
  tone      String   @default("formal") // formal, casual, technical
  level     String   @default("summary") // summary, detailed
  segment   String? // SOFTWARE, RETAIL, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AISector {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memories AIMemory[]
  chats    AIChat[]

  insightRules  AIInsightRule[]
  insightEvents AIInsightEvent[]

  @@unique([companyId, name])
}

model AIMemory {
  id         String                       @id @default(cuid())
  companyId  String
  company    Company                      @relation(fields: [companyId], references: [id])
  sectorId   String?
  sector     AISector?                    @relation(fields: [sectorId], references: [id])
  content    String
  tags       String[]
  embedding  Unsupported("vector(1536)")?
  validUntil DateTime?
  confidence Float                        @default(1.0)
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt

  @@index([companyId])
}

model AIDocument {
  id        String                       @id @default(cuid())
  companyId String
  company   Company                      @relation(fields: [companyId], references: [id])
  filename  String
  content   String
  summary   String?
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())

  @@index([companyId])
}

model AIChat {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  sectorId  String?
  sector    AISector? @relation(fields: [sectorId], references: [id])
  title     String
  status    String    @default("ACTIVE") // ACTIVE, ARCHIVED
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages AIMessage[]

  @@index([companyId, userId])
}

model AIMessage {
  id         String   @id @default(cuid())
  chatId     String
  chat       AIChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role       String // user, assistant, system
  content    String
  tokensUsed Int?
  feedback   String? // like, dislike
  createdAt  DateTime @default(now())

  @@index([chatId])
}

model AIMetricSnapshot {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  date        DateTime
  metricKey   String // revenue, expense, net_income
  value       Float
  granularity String // D, W, M
  createdAt   DateTime @default(now())

  @@unique([companyId, metricKey, date, granularity])
  @@index([companyId, date])
}

model AITask {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  type          String // analysis, categorization
  status        String // PENDING, IN_PROGRESS, COMPLETED, FAILED
