model SalePayment {
  id                      String         @id @default(cuid())
  saleId                  String
  sale                    Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethodId         String?
  paymentMethod           PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  externalPaymentMethodId String?
  amount                  Float          @default(0)
  createdAt               DateTime       @default(now())

  @@index([saleId])
}

// --- AI Insights Module ---

enum AIInsightSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AIInsightStatus {
  NEW
  SENT
  READ
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum AIInsightSourceType {
  RULE_ENGINE
  LLM_ANALYSIS
  MANUAL
}

enum AIChannelType {
  EMAIL
  WHATSAPP
  TELEGRAM
  IN_APP
}

enum AIInsightDeliveryStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum AIInsightFeedbackType {
  USEFUL
  IRRELEVANT
  FALSE_POSITIVE
  TOO_FREQUENT
  OTHER
}

model AIInsightRule {
  id        String    @id @default(cuid())
  companyId String? // Nullable for global rules
  company   Company?  @relation(fields: [companyId], references: [id])
  sectorId  String?
  sector    AISector? @relation(fields: [sectorId], references: [id])

  code            String            @unique // e.g. "REVENUE_DROP_WEEKLY"
  name            String
  description     String?
  insightType     String // e.g. "FINANCIAL_RISK"
  severityDefault AIInsightSeverity @default(MEDIUM)
  enabled         Boolean           @default(true)
  conditionsJson  String // JSON storing thresholds/logic parameters
  actionTemplate  String? // Template for the insight text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events AIInsightEvent[]

  @@index([companyId])
  @@index([sectorId])
}

model AIInsightEvent {
  id        String         @id @default(cuid())
  companyId String
  company   Company        @relation(fields: [companyId], references: [id])
  ruleId    String?
  rule      AIInsightRule? @relation(fields: [ruleId], references: [id])
  sectorId  String?
  sector    AISector?      @relation(fields: [sectorId], references: [id])

  title           String
  summary         String
  detailedContext String? // Using String for SQLite compatibility if needed, but PG supports Text. Prisma String maps to text.
  severity        AIInsightSeverity
  status          AIInsightStatus     @default(NEW)
  sourceType      AIInsightSourceType @default(RULE_ENGINE)
  metricReference String? // Key of the metric triggered
  payloadJson     String? // Snapshot data or specific numbers
  occurredAt      DateTime            @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipients       AIInsightRecipient[]
  feedback         AIInsightFeedback[]
  notificationLogs AINotificationLog[]

  @@index([companyId, status])
  @@index([ruleId])
}

model AIInsightRecipient {
  id             String         @id @default(cuid())
  insightEventId String
  insightEvent   AIInsightEvent @relation(fields: [insightEventId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?          @relation(fields: [userId], references: [id])

  externalChannelTarget String? // Phone number or email if not mapped to user
  channelType           AIChannelType           @default(IN_APP)
  deliveryStatus        AIInsightDeliveryStatus @default(PENDING)
  deliveredAt           DateTime?
  readAt                DateTime?

  createdAt DateTime @default(now())

  @@index([insightEventId])
  @@index([userId])
}

model AIInsightFeedback {
  id             String         @id @default(cuid())
  insightEventId String
  insightEvent   AIInsightEvent @relation(fields: [insightEventId], references: [id], onDelete: Cascade)
  userId         String
  user           User           @relation(fields: [userId], references: [id])

  feedbackType AIInsightFeedbackType
  comment      String?

  createdAt DateTime @default(now())

  @@index([insightEventId])
}

// --- Background Jobs ---

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model BackgroundJob {
  id          String    @id @default(cuid())
  queue       String // e.g. "INSIGHTS_GENERATION", "REPORT_GENERATION"
  payload     String // JSON
  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?
  runAt       DateTime  @default(now())

  startedAt  DateTime?
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([queue, status, runAt])
}

// --- Notification Module ---

model AINotificationChannel {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])

  type    AIChannelType
  target  String // email address, phone number, chat_id
  enabled Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, userId])
}

model AINotificationLog {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id])
  insightEventId String
  insightEvent   AIInsightEvent @relation(fields: [insightEventId], references: [id])

  channelType      AIChannelType
  target           String
  status           String // SENT, FAILED, PENDING
  providerResponse String? // JSON response from provider

  attemptedAt DateTime  @default(now())
  deliveredAt DateTime?

  @@index([companyId, insightEventId])
}
